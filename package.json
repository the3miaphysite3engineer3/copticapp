{
  "name": "coptic-compass",
  "description": "Coptic Compass: a digital Coptology platform with dictionary, grammar, publications, and learning tools.",
  "version": "0.1.0",
  "private": true,
  "author": "Kyrillos Wannes",
  "license": "MIT",
  "engines": {
    "node": "22.13.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KyroHub/CopticCompass.git"
  },
  "homepage": "https://www.copticcompass.com",
  "bugs": {
    "url": "https://github.com/KyroHub/CopticCompass/issues"
  },
  "keywords": [
    "coptic",
    "linguistics",
    "dictionary",
    "digital-humanities",
    "nextjs",
    "typescript",
    "tailwindcss",
    "recharts"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "dev:poll": "WATCHPACK_POLLING=true next dev --webpack",
    "prebuild": "npm run data:grammar:export",
    "build": "next build --webpack",
    "start": "next start",
    "db:migrations:list": "supabase migration list --linked",
    "db:push:dry-run": "supabase db push --linked --dry-run",
    "db:push": "supabase db push --linked",
    "db:drift:check": "supabase db diff --linked --schema public",
    "distill:extract": "node --experimental-strip-types scripts/distillExtractChunks.mts",
    "distill:teacher": "node --experimental-strip-types scripts/distillGenerateTeacherData.mts",
    "distill:build": "node --experimental-strip-types scripts/distillBuildDatasets.mts",
    "distill:pipeline": "npm run distill:extract && npm run distill:teacher && npm run distill:build",
    "assets:icon": "node --experimental-strip-types scripts/generateAppIcons.mts",
    "data:grammar:export": "node --experimental-strip-types scripts/exportGrammar.mts",
    "lint": "eslint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:local": "npm run build && npm run test:e2e",
    "knip": "knip",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/react": "^3.0.170",
    "@gradio/client": "^2.2.0",
    "@huggingface/inference": "^4.13.15",
    "@opentelemetry/api": "^1.9.1",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.168",
    "browser-image-compression": "^2.0.2",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.2",
    "swagger-ui-dist": "^5.32.4",
    "ts-fsrs": "^5.4.1"
  },
  "devDependencies": {
    "@next/env": "16.2.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "supabase": "^2.98.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
